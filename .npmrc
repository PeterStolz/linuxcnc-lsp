# Supply-chain hardening (pnpm 10+) — mirrors ~/.npmrc / our other repos.
# https://pnpm.io/settings

# Refuse anything published in the last 7 days (10080 minutes). Catches the
# typical compromise window before the registry/advisories catch up. With a
# frozen lockfile (CI) this only constrains *new* resolutions, so it never
# breaks reproducible installs.
minimum-release-age=10080

# Refuse to install if any package's peerDependencies range isn't met — turns
# silent version skew into an install-time error. Postinstall build scripts
# stay opt-in via `pnpm.onlyBuiltDependencies` in package.json (pnpm 10 default).
strict-peer-dependencies=true

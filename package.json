{
  "name": "linuxcnc-lsp-monorepo",
  "version": "0.1.4",
  "private": true,
  "description": "Language Server + VSCode extension for LinuxCNC HAL, INI and G-code files",
  "license": "GPL-2.0-or-later",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc -b && tsc -p packages/client/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "gen:db": "tsx scripts/regenerate-db.ts",
    "corpus": "tsx scripts/corpus-check.ts",
    "package": "pnpm run build && cd packages/client && vsce package --no-dependencies -o ../../linuxcnc-lsp.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.23.0",
    "eslint": "^9.9.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
